# .coveragerc - Configuration for coverage.py

[run]
source =
    src/
omit =
    */tests/*
    */__init__.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if self.debug:
    if __name__ == .__main__.:
    raise AssertionError
    raise NotImplementedError
    if 0:
    if __debug__:

show_missing = True
skip_covered = False
precision = 2

[html]
directory = htmlcov

[xml]
output = coverage.xml
